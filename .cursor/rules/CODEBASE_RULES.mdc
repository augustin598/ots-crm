### Common Patterns

#### Creating a Tenant-Scoped Resource

```typescript
// In remote function
export const createResource = command(schema, async (data) => {
  const event = getRequestEvent();
  if (!event?.locals.user || !event?.locals.tenant) {
    throw new Error("Unauthorized");
  }

  await db.insert(table.resource).values({
    id: generateId(),
    tenantId: event.locals.tenant.id,
    ...data,
  });

  return { success: true };
});
```

#### Filtering by Tenant

```typescript
const resources = await db
  .select()
  .from(table.resource)
  .where(eq(table.resource.tenantId, event.locals.tenant.id));
```

#### Romanian CUI Lookup

```typescript
import { getCompanyData } from "$lib/remotes/anaf.remote";

// In component
async function lookupCUI() {
  try {
    const data = await getCompanyData(cui);
    // Auto-fill form fields with Romanian company data
    companyName = data.denumire;
    address = data.adresa;
    // ... etc
  } catch (e) {
    error = e instanceof Error ? e.message : "Failed to lookup CUI";
  }
}
```

