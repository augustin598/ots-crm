## Authentication (Lucia-style)

### Architecture

This codebase uses a custom Lucia-style authentication implementation. Authentication logic is centralized in `src/lib/server/auth.ts`.

### Session Management

#### Creating Sessions

```typescript
import * as auth from "$lib/server/auth";

const sessionToken = auth.generateSessionToken();
const session = await auth.createSession(sessionToken, userId);
auth.setSessionTokenCookie(event, sessionToken, session.expiresAt);
```

#### Validating Sessions

Sessions are automatically validated in `hooks.server.ts`. Access the user via `event.locals.user`:

```typescript
export const load: PageServerLoad = async (event) => {
  if (!event.locals.user) {
    throw redirect(302, "/login");
  }

  return {
    user: event.locals.user,
  };
};
```

#### Invalidating Sessions

```typescript
import * as auth from "$lib/server/auth";

await auth.invalidateSession(sessionId);
auth.deleteSessionTokenCookie(event);
```

### Password Hashing

Use `@node-rs/argon2` for password hashing:

```typescript
import { hash, verify } from "@node-rs/argon2";

// Hashing
const passwordHash = await hash(password, {
  memoryCost: 19456,
  timeCost: 2,
  outputLen: 32,
  parallelism: 1,
});

// Verification
const validPassword = await verify(existingUser.passwordHash, password, {
  memoryCost: 19456,
  timeCost: 2,
  outputLen: 32,
  parallelism: 1,
});
```

### User ID Generation

Generate secure user IDs:

```typescript
import { encodeBase32LowerCase } from "@oslojs/encoding";

function generateUserId() {
  const bytes = crypto.getRandomValues(new Uint8Array(15));
  return encodeBase32LowerCase(bytes);
}
```

### Authentication Flow with Remote Functions

#### Login Command

```typescript
// src/routes/login/auth.remote.ts
import { command } from "$app/server";
import { getRequestEvent, redirect } from "@sveltejs/kit";
import * as v from "valibot";
import { hash, verify } from "@node-rs/argon2";
import { eq } from "drizzle-orm";
import * as auth from "$lib/server/auth";
import { db } from "$lib/server/db";
import * as table from "$lib/server/db/schema";

const loginSchema = v.object({
  username: v.string(),
  password: v.string(),
});

export const login = command(loginSchema, async (data) => {
  const event = getRequestEvent();
  const { username, password } = data;

  // Validate credentials
  const [user] = await db
    .select()
    .from(table.user)
    .where(eq(table.user.username, username));

  if (!user) {
    throw new Error("Incorrect username or password");
  }

  const validPassword = await verify(user.passwordHash, password, {
    memoryCost: 19456,
    timeCost: 2,
    outputLen: 32,
    parallelism: 1,
  });

  if (!validPassword) {
    throw new Error("Incorrect username or password");
  }

  // Create session
  const sessionToken = auth.generateSessionToken();
  const session = await auth.createSession(sessionToken, user.id);
  auth.setSessionTokenCookie(event, sessionToken, session.expiresAt);

  return { success: true, userId: user.id };
});
```

#### Registration Command

```typescript
// src/routes/login/auth.remote.ts
import { encodeBase32LowerCase } from "@oslojs/encoding";

const registerSchema = v.object({
  username: v.string(),
  password: v.string(),
});

export const register = command(registerSchema, async (data) => {
  const event = getRequestEvent();
  const { username, password } = data;

  // Validate username
  if (
    !/^[a-z0-9_-]+$/.test(username) ||
    username.length < 3 ||
    username.length > 31
  ) {
    throw new Error("Invalid username");
  }

  // Check if user exists
  const [existing] = await db
    .select()
    .from(table.user)
    .where(eq(table.user.username, username));

  if (existing) {
    throw new Error("Username already taken");
  }

  // Create user
  const userId = generateUserId();
  const passwordHash = await hash(password, {
    memoryCost: 19456,
    timeCost: 2,
    outputLen: 32,
    parallelism: 1,
  });

  await db.insert(table.user).values({ id: userId, username, passwordHash });

  // Create session immediately after registration
  const sessionToken = auth.generateSessionToken();
  const session = await auth.createSession(sessionToken, userId);
  auth.setSessionTokenCookie(event, sessionToken, session.expiresAt);

  return { success: true, userId };
});

function generateUserId() {
  const bytes = crypto.getRandomValues(new Uint8Array(15));
  return encodeBase32LowerCase(bytes);
}
```

#### Logout Command

```typescript
// src/routes/logout/auth.remote.ts
import { command, getRequestEvent } from "$app/server";
import * as auth from "$lib/server/auth";

export const logout = command(async () => {
  const event = getRequestEvent();

  if (!event.locals.session) {
    throw new Error("Not authenticated");
  }

  await auth.invalidateSession(event.locals.session.id);
  auth.deleteSessionTokenCookie(event);

  return { success: true };
});
```

#### Using Authentication Commands in Components

```svelte
<!-- src/routes/login/+page.svelte -->
<script lang="ts">
	import { login, register } from './auth.remote';
	import { goto } from '$app/navigation';

	let username = $state('');
	let password = $state('');
	let loading = $state(false);
	let error = $state<string | null>(null);
	let isRegistering = $state(false);

	async function handleSubmit() {
		loading = true;
		error = null;

		try {
			if (isRegistering) {
				await register({ username, password });
			} else {
				await login({ username, password });
			}
			// Redirect after successful login/register
			goto('/dashboard');
		} catch (e) {
			error = e instanceof Error ? e.message : 'An error occurred';
		} finally {
			loading = false;
		}
	}
</script>

<form
	onsubmit={(e) => {
		e.preventDefault();
		handleSubmit();
	}}
>
	<input bind:value={username} placeholder="Username" />
	<input type="password" bind:value={password} placeholder="Password" />
	<button type="submit" disabled={loading}>
		{loading ? 'Processing...' : isRegistering ? 'Register' : 'Login'}
	</button>
</form>

<button onclick={() => (isRegistering = !isRegistering)}>
	{isRegistering ? 'Switch to Login' : 'Switch to Register'}
</button>

{#if error}
	<p style="color: red">{error}</p>
{/if}
```

### Protecting Routes

#### Server-side Protection

```typescript
// In +page.server.ts
export const load: PageServerLoad = async (event) => {
  if (!event.locals.user) {
    throw redirect(302, "/login");
  }

  return {
    user: event.locals.user,
  };
};
```

#### Using getRequestEvent() with Remote Functions

```typescript
import { getRequestEvent } from "$app/server";

function requireLogin() {
  const { locals } = getRequestEvent();

  if (!locals.user) {
    throw redirect(302, "/login");
  }

  return locals.user;
}

export const getProtectedData = query(async () => {
  const user = requireLogin();
  // Use user...
});
```

### Best Practices

1. **Always validate passwords** - Check length and complexity
2. **Use secure session tokens** - Generated with crypto.getRandomValues
3. **Hash session tokens** - Store hashed tokens in database
4. **Set appropriate cookie options** - httpOnly, secure, sameSite
5. **Renew sessions** - Automatically renew before expiration
6. **Invalidate on logout** - Always delete session from database
7. **Handle errors gracefully** - Don't reveal if username exists

