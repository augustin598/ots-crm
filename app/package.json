	"type": "module",
	"scripts": {
		"dev": "bunx --bun vite dev",
		"build": "bunx --bun vite build",
		"preview": "vite preview",
		"prepare": "bunx --bun svelte-kit sync || echo ''",
		"check": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json --watch",
		"sync": "bun scripts/generate-sitemap.ts && bun scripts/generate-route-cms-variables.ts && echo ''",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:pull": "drizzle-kit pull",
		"db:migrate": "drizzle-kit migrate",
		"db:check": "drizzle-kit check",
		"db:studio": "drizzle-kit studio",
		"db:seed": "bun --bun scripts/seed.ts",
		"db:create-admin": "bun --bun scripts/create-admin.ts",
		"import:smartbill": "bun --bun scripts/import-smartbill-excel.ts",
		"test:anaf-oauth": "bun --bun scripts/test-anaf-oauth.ts",
		"test:smtp": "bun --bun scripts/test-smtp.ts"
